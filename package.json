{
  "name": "superagent",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "desktop:dev": "bun --filter desktop tauri:dev",
    "desktop:dev:rebuild": "bun --filter desktop tauri:dev:rebuild",
    "desktop:build": "bun --filter desktop tauri build",
    "lint": "oxlint apps/ packages/",
    "format": "oxfmt apps/ packages/",
    "postinstall": "lefthook install",
    "db:reset": "trash ~/.superagent/superagent.db && echo 'Database reset. Restart the app to recreate.'"
  },
  "catalog": {
    "@tauri-apps/api": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "ghostty-web": "^0.4.0",
    "happy-dom": "^20.8.9",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
