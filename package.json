{
  "name": "canopy",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "desktop:dev": "bun run --cwd apps/desktop tauri:dev",
    "desktop:dev:rebuild": "bun run --cwd apps/desktop tauri:dev:rebuild",
    "desktop:build": "bun --filter desktop tauri build",
    "desktop:build:local": "bun --filter desktop tauri:build:local",
    "desktop:open": "open target/release/bundle/macos/Canopy.app",
    "lint": "oxlint apps/ packages/",
    "format": "oxfmt apps/ packages/",
    "postinstall": "lefthook install",
    "desktop:db:reset": "bun --filter desktop db:reset",
    "desktop:db:reset:prod": "bun --filter desktop db:reset:prod",
    "clean": "bun run clean:js && bun run clean:rust",
    "clean:js": "trash node_modules/.cache",
    "clean:rust": "cd apps/desktop/src-tauri && cargo clean",
    "clean:all": "bun run clean && trash node_modules"
  },
  "catalog": {
    "@tauri-apps/api": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "ghostty-web": "npm:@canopy-hq/ghostty-web@0.6.0-next.5.g8f94eca",
    "happy-dom": "^20.8.9",
    "react": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
