#!/bin/sh
# canopy-notify — hook callback for Canopy agent state detection
# Safe no-op when Canopy is not running or outside Canopy terminals.
# Installed by Canopy at startup; never cleaned up (harmless when idle).
[ -z "$CANOPY_DAEMON_SOCK" ] && exit 0

# Resolve CANOPY_PANE_ID: set at spawn time for fresh PTYs, or discovered
# via sidecar file for pool-claimed PTYs (where env vars can't be injected
# without visible terminal output).
if [ -z "$CANOPY_PANE_ID" ]; then
  _pid=$$
  while [ "$_pid" != "1" ] && [ "$_pid" != "0" ] && [ -n "$_pid" ]; do
    _file="$HOME/.canopy/run/$_pid"
    if [ -f "$_file" ]; then
      CANOPY_PANE_ID=$(cat "$_file")
      break
    fi
    _pid=$(ps -o ppid= -p "$_pid" 2>/dev/null | tr -d ' ')
  done
  [ -z "$CANOPY_PANE_ID" ] && exit 0
fi

python3 - "$CANOPY_DAEMON_SOCK" "$CANOPY_PANE_ID" \
         "$CANOPY_HOOK_EVENT" "${CANOPY_AGENT:-unknown}" "${PPID:-0}" <<'PYEOF' 2>/dev/null || true
import socket, sys, json
try:
    sock_path, pane_id, event, agent, ppid = sys.argv[1:6]
    msg = json.dumps({
        "op": "hook_notify",
        "paneId": pane_id,
        "event": event,
        "agentName": agent,
        "pid": int(ppid),
    })
    with socket.socket(socket.AF_UNIX) as s:
        s.settimeout(1)
        s.connect(sock_path)
        s.sendall(msg.encode() + b'\n')
except Exception:
    pass
PYEOF
