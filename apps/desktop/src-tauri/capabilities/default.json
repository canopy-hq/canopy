{
  "identifier": "default",
  "description": "Default capability for Canopy",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "store:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "updater:default"
  ]
}
