{
  "productName": "Canopy",
  "version": "0.1.0",
  "identifier": "com.canopy.app",
  "build": {
    "beforeDevCommand": "cargo build --bin canopy-pty-daemon --manifest-path ../../packages/pty-daemon/Cargo.toml",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cargo build --release --bin canopy-pty-daemon --manifest-path ../../packages/pty-daemon/Cargo.toml && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Canopy",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a14",
        "trafficLightPosition": { "x": 12, "y": 26 }
      }
    ],
    "security": { "csp": null },
    "macOSPrivateApi": true
  },
  "bundle": {
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "macOS": { "bundleName": "Canopy" }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4MjFDNDhFQUZFMjMwNTUKUldSVk1PS3Zqc1FobURUclBmaVJlWkVtRUtQVWQ1L202eDFDY2ZkM1hMR2VYaW12MjlFbUlwbTEK",
      "endpoints": ["https://github.com/nept/superagent/releases/latest/download/latest.json"]
    }
  }
}
